# Copy this file to .env in your project root.
# Replace the values below with your Supabase project details.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-supabase-key
# If you prefer, `NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY` is also accepted by the build script.
